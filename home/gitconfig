# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = Daniel Hobe
	email = hobe@gmail.com

# ==============================================================================
# Core
# ==============================================================================

[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[init]
	defaultBranch = main


# ==============================================================================
# Behavior
# ==============================================================================

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[branch]
	sort = -committerdate

[rebase]
	autoSquash = true
	autoStash = true

# ==============================================================================
# Colors
# ==============================================================================

[color]
	ui = auto

# ==============================================================================
# Aliases
# ==============================================================================

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	amend = commit --amend --no-edit
	unstage = reset HEAD --
	last = log -1 HEAD
	lg = log --oneline --graph --decorate -20
	branches = branch -a
	tags = tag -l
	stashes = stash list
	discard = checkout --
	# Show combined diff of last N commits touching a file: git file-diff 4 path/to/file
	# Note: File must have commit history (won't work for new/untracked files)
	file-diff = "!f() { git diff $(git log --format='%H' -$1 -- $2 | tail -1)^..HEAD -- $2; }; f"
	# Unified (non-side-by-side) versions for easy copying
	diffu = "!git -c delta.side-by-side=false diff"
	file-diffu = "!f() { git -c delta.side-by-side=false diff $(git log --format='%H' -$1 -- $2 | tail -1)^..HEAD -- $2; }; f"

# GitHub-specific override: Use gh CLI
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[include]
	path = ~/.gitconfig.tokyonight
