#!/bin/bash
# keyboard-settings — apply keyboard and mouse settings for the current X session
#
# Called by keyboard-reset.service (triggered on USB keyboard add and suspend resume).
# Safe to run multiple times.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve display / authority
# ---------------------------------------------------------------------------
: "${DISPLAY:=:0}"
: "${XAUTHORITY:=$HOME/.Xauthority}"
export DISPLAY XAUTHORITY

# Bail out early if X is not reachable (e.g. called before login completes)
if ! xset q &>/dev/null; then
    echo "keyboard-settings: X display $DISPLAY not available, skipping" >&2
    exit 0
fi

# ---------------------------------------------------------------------------
# xset
# ---------------------------------------------------------------------------
xset r rate 220 30

# ---------------------------------------------------------------------------
# xmodmap
# ---------------------------------------------------------------------------
if [[ -f "$HOME/.Xmodmap" ]]; then
    xmodmap "$HOME/.Xmodmap"
fi

# ---------------------------------------------------------------------------
# xinput
# ---------------------------------------------------------------------------

# Evoluent VerticalMouse 4 — remap buttons
for mouse in "Kingsis Peripherals Evoluent VerticalMouse 4" "Evoluent VerticalMouse 4"; do
    if xinput list --name-only 2>/dev/null | grep -qF "$mouse"; then
        xinput set-button-map "$mouse" 1 3 8 4 5 6 7 9 2 8
    fi
done

# ---------------------------------------------------------------------------
notify-send -t 2500 "Keyboard settings applied" 2>/dev/null || true
