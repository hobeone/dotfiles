#!/bin/bash
# keyboard-settings — apply keyboard and mouse settings for the current X session
#
# Called by keyboard-reset.service (triggered on USB keyboard add and suspend resume).
# Safe to run multiple times.

set -xuo pipefail

# ---------------------------------------------------------------------------
# Resolve display / authority
# ---------------------------------------------------------------------------
# When invoked from a udev/systemd service, DISPLAY and XAUTHORITY are not
# set. Discover them from the environment of a process that is already
# connected to the X session (e.g. the window manager or desktop session).
if [[ -z "${DISPLAY:-}" || -z "${XAUTHORITY:-}" ]]; then
    for pid in $(pgrep -u "${SUDO_USER:-$USER}" -x "Xorg|X|openbox|i3|sway|gnome-session|xfce4-session|startx" 2>/dev/null); do
        env_file="/proc/$pid/environ"
        [[ -r "$env_file" ]] || continue
        _d=$(tr '\0' '\n' < "$env_file" | grep '^DISPLAY=' | cut -d= -f2-)
        _xa=$(tr '\0' '\n' < "$env_file" | grep '^XAUTHORITY=' | cut -d= -f2-)
        if [[ -n "$_d" ]]; then
            DISPLAY="$_d"
            [[ -n "$_xa" ]] && XAUTHORITY="$_xa"
            break
        fi
    done
fi

: "${DISPLAY:=:0}"
: "${XAUTHORITY:=$HOME/.Xauthority}"
export DISPLAY XAUTHORITY

# Bail out early if X is not reachable (e.g. called before login completes)
if ! xset q &>/dev/null; then
    echo "keyboard-settings: X display $DISPLAY not available, skipping" >&2
    exit 0
fi

# ---------------------------------------------------------------------------
# xset
# ---------------------------------------------------------------------------
xset r rate 220 30

# ---------------------------------------------------------------------------
# xmodmap
# ---------------------------------------------------------------------------
if [[ -f "$HOME/.Xmodmap" ]]; then
    xmodmap -verbose "$HOME/.Xmodmap"
fi

# ---------------------------------------------------------------------------
# xinput
# ---------------------------------------------------------------------------

# Evoluent VerticalMouse 4 — remap buttons
for mouse in "Kingsis Peripherals Evoluent VerticalMouse 4" "Evoluent VerticalMouse 4"; do
    if xinput list --name-only 2>/dev/null | egrep -q "^$mouse"; then
        echo "Found $mouse, setting button map"
        xinput set-button-map "$mouse" 1 3 8 4 5 6 7 9 2 8
    fi
done

# ---------------------------------------------------------------------------
echo "Set Keyboard Settings"
notify-send -t 2500 "Keyboard settings applied" 2>/dev/null || true
