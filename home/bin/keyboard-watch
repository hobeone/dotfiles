#!/bin/bash
# keyboard-watch — X session daemon: re-apply keyboard settings on device changes
#
# Monitors udev for input device additions. The --udev flag ensures we see events
# after udev finishes processing (rather than the raw kernel event), giving X more
# time to initialize the device. The sleep lets X finish resetting the global XKB
# keymap before keyboard-settings runs.
#
# Previously used `xinput test-xi2 --root`, which selects all XI2 events on the
# root window and interferes with Openbox receiving mouse events on the desktop.
#
# started by ~/.config/openbox/autostart

set -euo pipefail

LOCK="/tmp/keyboard-watch.lock"

apply() {
    ( flock -n 200 || exit 0
      keyboard-settings
    ) 200>"$LOCK" &
}

# Apply once at session start
apply
wait

# Watch for input device additions (KVM switch, USB plug/unplug)
udevadm monitor --udev --subsystem-match=input 2>/dev/null \
    | grep --line-buffered ' add ' \
    | while IFS= read -r _; do
          sleep 1
          apply
      done
